[features]
hooks = true

[sandbox_workspace_write]
network_access = false

[auto_review]
policy = """
Deny requests that:
- delete broad filesystem targets such as /, ~, $HOME, .., .git, or large glob
patterns
- modify files outside the current project unless explicitly requested
- bypass security hooks or checks, including --no-verify, core.hooksPath changes,
or disabling hook tools
- print, copy, upload, or exfiltrate secrets
- run network access to unknown hosts without clear user intent

Allow normal project-local development work.
Allow GitHub/GitLab-related development network actions when the command intent
is clear, such as git fetch, git pull, git push, gh pr/issue/check commands, and
glab equivalents.

Allow Butty Cloudflare tooling secret injection as a policy-managed capability,
not as a wrapper-only or parent-env-only capability. Allow it only when all
conditions hold:
- the command is scoped to the active Butty worktree under `$HOME/Dev/butty`
- `OP_CONNECT_HOST` and `OP_CONNECT_TOKEN` are absent
- Service Account token resolution happens only through repository entrypoints
  `pnpm cf:shell:check` or `pnpm cf:shell -- ...`; direct `op read`, arbitrary
  command substitution, Keychain reads, shell history reads, and plaintext
  `.env` reads remain denied
- 1Password environment injection after that point is via
  `pnpm cf:op:run --template <purpose> -- <allowlisted command>` or the
  underlying `op run --env-file=infra/cloudflare/.env.*.template -- ...`
- the template path is under `infra/cloudflare/`
- output remains redacted JSON/audit output
- the command does not print environment variables, read raw secret values,
  write plaintext `.env.local` fallbacks, or pass secret values on the command
  line

Allow read-only Cloudflare / Resend observability commands when the command
matches one of:
- `pnpm cf:shell:check`
- `pnpm cf:shell -- pnpm cf:op:run --template auth-check -- pnpm cf:auth:check`
- `pnpm cf:shell -- pnpm cf:op:run --template logs -- pnpm cf:logs:*`
- `pnpm cf:shell -- pnpm cf:op:run --template resend-observability -- pnpm resend:logs:recent`

Allow only this external-state-changing Cloudflare secret sync command:
`pnpm cf:shell -- pnpm cf:op:run --template apns-preview -- pnpm cf:apns-secrets:sync`

When:
- cwd / --dir is inside `$HOME/Dev/butty`
- template is `infra/cloudflare/.env.apns-preview.template`
- `CLOUDFLARE_ENV=preview`
- `BUTTY_CF_TEMPLATE_PURPOSE=apns-preview`
- `BUTTY_CF_TOKEN_SCOPE=apns-preview-secret-sync`
- destination is Cloudflare preview Worker only
- written keys are exactly:
  APNS_AUTH_KEY
  APNS_KEY_ID
  APNS_TEAM_ID
  APNS_TOPIC
  APNS_HOST
- output is redacted JSON/audit output only
- no raw env dump, no `.env.local` write, no command-line secret values

Do not allow deploy, Worker secret writes, runtime secret sync, database origin
reads, or other external-state-changing Cloudflare tooling under the read-only
observability allowance. Those require a separate purpose-specific allowance and
ad-hoc approval.

Allow 1Password item scaffolding only for non-secret metadata in vault
`butty-dev` and item names prefixed with `cloudflare-`; secret field values
must be entered by a human in 1Password or injected by `op run`, not included
in shell commands or logs.
"""

[profiles.net]
sandbox_mode = "workspace-write"
approval_policy = "on-request"
approvals_reviewer = "auto_review"

[profiles.net.sandbox_workspace_write]
network_access = true

[profiles.readonly]
sandbox_mode = "read-only"
approval_policy = "never"

[notice]
hide_rate_limit_model_nudge = true
fast_default_opt_out = true

[notice.model_migrations]
"gpt-5.3-codex" = "gpt-5.4"

[model_providers.openai-cli]
name = "OpenAI (CLI dev)"
base_url = "https://api.openai.com/v1"
wire_api = "responses"
env_key = "CODEX_API_KEY"
env_key_instructions = "Set CODEX_API_KEY env var (separate from Butty's OPENAI_API_KEY)"

[profiles.api]
model_provider = "openai-cli"

[tui]
status_line = [
  "model-with-reasoning",
  "project-root",
  "context-remaining",
  "git-branch",
  "five-hour-limit",
  "weekly-limit",
]

[plugins."github@openai-curated"]
enabled = true
