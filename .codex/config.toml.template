[features]
hooks = true

[sandbox_workspace_write]
network_access = false

[auto_review]
policy = """
Deny requests that:
- delete broad filesystem targets such as /, ~, $HOME, .., .git, or large glob
patterns
- modify files outside the current project unless explicitly requested
- bypass security hooks or checks, including --no-verify, core.hooksPath changes,
or disabling hook tools
- print, copy, upload, or exfiltrate secrets
- run network access to unknown hosts without clear user intent

Allow normal project-local development work.
Allow GitHub/GitLab-related development network actions when the command intent
is clear, such as git fetch, git pull, git push, gh pr/issue/check commands, and
glab equivalents.

Use 1Password MCP Server for Codex and 1Password Environments as the standard
path for Butty AI-agent secret access. The agent may manage 1Password
Environment metadata, variable names, and local mounted `.env` destinations, but
must not request, print, copy, or return raw secret values. 1Password desktop app
authorization must remain the human-controlled boundary.

Treat Service Account based Cloudflare secret injection as legacy fallback, not
the standard Codex path. Do not broaden local auto-review policy to pass
`OP_SERVICE_ACCOUNT_TOKEN` into the Codex process, run arbitrary `op read`, dump
environment variables, write plaintext `.env.local` fallbacks, or place secret
values on command lines. If fallback is unavoidable, use the Cloudflare tooling
runbook and ADR-0032; keep read-only observability separate from deploy,
Worker secret writes, runtime secret sync, APNs secret sync, database origin
reads, and other external-state-changing tooling.
"""

[profiles.net]
sandbox_mode = "workspace-write"
approval_policy = "on-request"
approvals_reviewer = "auto_review"

[profiles.net.sandbox_workspace_write]
network_access = true

[profiles.readonly]
sandbox_mode = "read-only"
approval_policy = "never"

[notice]
hide_rate_limit_model_nudge = true
fast_default_opt_out = true

[notice.model_migrations]
"gpt-5.3-codex" = "gpt-5.4"

[model_providers.openai-cli]
name = "OpenAI (CLI dev)"
base_url = "https://api.openai.com/v1"
wire_api = "responses"
env_key = "CODEX_API_KEY"
env_key_instructions = "Set CODEX_API_KEY env var (separate from Butty's OPENAI_API_KEY)"

[profiles.api]
model_provider = "openai-cli"

[tui]
status_line = [
  "model-with-reasoning",
  "project-root",
  "context-remaining",
  "git-branch",
  "five-hour-limit",
  "weekly-limit",
]

[plugins."github@openai-curated"]
enabled = true
